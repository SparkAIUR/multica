# =============================================================================
# Coolify Production Environment Example
# =============================================================================
# Copy these values into Coolify environment variables for the production stack.

# Image selection
MULTICA_BACKEND_IMAGE=hub.nu-dev.io/multica/backend:latest
MULTICA_WEB_IMAGE=hub.nu-dev.io/multica/web:latest
# Docker Hub alternatives:
# MULTICA_BACKEND_IMAGE=nudevco/multica-backend:latest
# MULTICA_WEB_IMAGE=nudevco/multica-web:latest

# Database
POSTGRES_DB=multica
POSTGRES_USER=multica
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://multica:change-me@postgres:5432/multica?sslmode=disable

# Backend / App
JWT_SECRET=change-me-to-a-long-random-secret
FRONTEND_ORIGIN=https://multica.example.com
CORS_ALLOWED_ORIGINS=https://multica.example.com
MULTICA_APP_URL=https://multica.example.com

# Keycloak
KEYCLOAK_ISSUER_URL=https://keycloak.example.com/realms/multica
KEYCLOAK_CLIENT_ID=multica-web
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_REDIRECT_URI=https://multica.example.com/auth/callback
# Comma-separated exact group names. Empty means allow all authenticated users.
KEYCLOAK_ALLOWED_GROUPS=

# Optional email
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@multica.ai
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# S3 / MinIO / CloudFront
S3_BUCKET=
S3_REGION=us-west-2
AWS_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=
COOKIE_DOMAIN=
