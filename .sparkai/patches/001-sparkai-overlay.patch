+# =============================================================================
+# Docker Compose - Coolify Staging Deployment
+# =============================================================================
+#
+# This file is designed for image-based deployment on Coolify.
+# It does not build locally; it pulls published images.
+#
+# Recommended image inputs:
+#   MULTICA_BACKEND_IMAGE=hub.nu-dev.io/multica/backend:<tag>
+#   MULTICA_WEB_IMAGE=hub.nu-dev.io/multica/web:<tag>
+#
+# Docker Hub alternatives:
+#   MULTICA_BACKEND_IMAGE=nudevco/multica-backend:<tag>
+#   MULTICA_WEB_IMAGE=nudevco/multica-web:<tag>
+#
+# Coolify should expose `frontend:3000` as the public app service.
+
+name: multica-coolify-staging
+
+services:
+  frontend:
+    image: ${MULTICA_WEB_IMAGE:-hub.nu-dev.io/multica/web:staging}
+    restart: unless-stopped
+    pull_policy: always
+    expose:
+      - "3000"
+    depends_on:
+      backend:
+        condition: service_healthy
+    environment:
+      HOSTNAME: "0.0.0.0"
+      PORT: "3000"
+    healthcheck:
+      test: ["CMD-SHELL", "wget -q -O- http://127.0.0.1:3000/ >/dev/null || exit 1"]
+      interval: 20s
+      timeout: 5s
+      retries: 10
+      start_period: 20s
+
+  backend:
+    image: ${MULTICA_BACKEND_IMAGE:-hub.nu-dev.io/multica/backend:staging}
+    restart: unless-stopped
+    pull_policy: always
+    expose:
+      - "8080"
+    depends_on:
+      postgres:
+        condition: service_healthy
+    environment:
+      # DB / server
+      DATABASE_URL: ${DATABASE_URL:-postgres://multica:multica@postgres:5432/multica?sslmode=disable}
+      PORT: "8080"
+      JWT_SECRET: ${JWT_SECRET:?JWT_SECRET is required}
+      FRONTEND_ORIGIN: ${FRONTEND_ORIGIN:?FRONTEND_ORIGIN is required}
+      CORS_ALLOWED_ORIGINS: ${CORS_ALLOWED_ORIGINS:-}
+      MULTICA_APP_URL: ${MULTICA_APP_URL:?MULTICA_APP_URL is required}
+
+      # Keycloak SSO
+      KEYCLOAK_ISSUER_URL: ${KEYCLOAK_ISSUER_URL:?KEYCLOAK_ISSUER_URL is required}
+      KEYCLOAK_CLIENT_ID: ${KEYCLOAK_CLIENT_ID:?KEYCLOAK_CLIENT_ID is required}
+      KEYCLOAK_CLIENT_SECRET: ${KEYCLOAK_CLIENT_SECRET:?KEYCLOAK_CLIENT_SECRET is required}
+      KEYCLOAK_REDIRECT_URI: ${KEYCLOAK_REDIRECT_URI:?KEYCLOAK_REDIRECT_URI is required}
+      KEYCLOAK_ALLOWED_GROUPS: ${KEYCLOAK_ALLOWED_GROUPS:-}
+
+      # Optional outbound email
+      RESEND_API_KEY: ${RESEND_API_KEY:-}
+      RESEND_FROM_EMAIL: ${RESEND_FROM_EMAIL:-noreply@multica.ai}
+      SMTP_HOST: ${SMTP_HOST:-}
+      SMTP_PORT: ${SMTP_PORT:-587}
+      SMTP_USERNAME: ${SMTP_USERNAME:-}
+      SMTP_PASSWORD: ${SMTP_PASSWORD:-}
+      SMTP_FROM_EMAIL: ${SMTP_FROM_EMAIL:-}
+
+      # S3 / MinIO / CloudFront
+      S3_BUCKET: ${S3_BUCKET:-}
+      S3_REGION: ${S3_REGION:-us-west-2}
+      AWS_ENDPOINT_URL: ${AWS_ENDPOINT_URL:-}
+      AWS_ACCESS_KEY_ID: ${AWS_ACCESS_KEY_ID:-}
+      AWS_SECRET_ACCESS_KEY: ${AWS_SECRET_ACCESS_KEY:-}
+      CLOUDFRONT_DOMAIN: ${CLOUDFRONT_DOMAIN:-}
+      CLOUDFRONT_KEY_PAIR_ID: ${CLOUDFRONT_KEY_PAIR_ID:-}
+      CLOUDFRONT_PRIVATE_KEY: ${CLOUDFRONT_PRIVATE_KEY:-}
+      COOKIE_DOMAIN: ${COOKIE_DOMAIN:-}
+    volumes:
+      - backend_data:/app/data
