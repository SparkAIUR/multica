diff --git a/.github/workflows/docker-publish.yml b/.github/workflows/docker-publish.yml
new file mode 100644
index 0000000000000000000000000000000000000000..f03b6f8f81b6de0d96773c54ed7946dba96dd843
--- /dev/null
+++ b/.github/workflows/docker-publish.yml
@@ -0,0 +1,200 @@
+name: Docker Publish
+
+on:
+  push:
+    tags:
+      - "v*"
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+jobs:
+  build-and-push:
+    runs-on: ubuntu-latest
+    outputs:
+      dockerhub_backend_ref: ${{ steps.refs.outputs.dockerhub_backend_ref }}
+      dockerhub_web_ref: ${{ steps.refs.outputs.dockerhub_web_ref }}
+      nudev_backend_ref: ${{ steps.refs.outputs.nudev_backend_ref }}
+      nudev_web_ref: ${{ steps.refs.outputs.nudev_web_ref }}
+    steps:
+      # - name: Validate registry credentials
+      #   run: |
+      #     set -euo pipefail
+      #     test -n "${{ secrets.DOCKERHUB_USERNAME }}" || (echo "DOCKERHUB_USERNAME secret is required" && exit 1)
+      #     test -n "${{ secrets.DOCKERHUB_TOKEN }}" || (echo "DOCKERHUB_TOKEN secret is required" && exit 1)
+      #     test -n "${{ secrets.REGISTRY_USERNAME }}" || (echo "REGISTRY_USERNAME secret is required" && exit 1)
+      #     test -n "${{ secrets.REGISTRY_PASSWORD }}" || (echo "REGISTRY_PASSWORD secret is required" && exit 1)
+
+      - name: Checkout
+        uses: actions/checkout@v4
+
+      - name: Setup Docker Buildx
+        uses: docker/setup-buildx-action@v3
+
+      - name: Login to Docker Hub
+        uses: docker/login-action@v3
+        with:
+          username: ${{ secrets.DOCKERHUB_USERNAME }}
+          password: ${{ secrets.DOCKERHUB_TOKEN }}
+
+      - name: Login to NuDev registry
+        uses: docker/login-action@v3
+        with:
+          registry: ${{ secrets.REGISTRY_URL }}
+          username: ${{ secrets.REGISTRY_USERNAME }}
+          password: ${{ secrets.REGISTRY_PASSWORD }}
+
+      - name: Compute image refs
+        id: refs
+        run: |
+          set -euo pipefail
+          short_sha="${GITHUB_SHA::7}"
+
+          dockerhub_backend_base="nudevco/multica-backend"
+          dockerhub_web_base="nudevco/multica-web"
+          nudev_backend_base="${{ secrets.REGISTRY_URL }}/multica/backend"
+          nudev_web_base="${{ secrets.REGISTRY_URL }}/multica/web"
+
+          backend_tags=(
+            "${dockerhub_backend_base}:sha-${short_sha}"
+            "${nudev_backend_base}:sha-${short_sha}"
+          )
+          web_tags=(
+            "${dockerhub_web_base}:sha-${short_sha}"
+            "${nudev_web_base}:sha-${short_sha}"
+          )
+
+          if [[ "${GITHUB_REF}" == refs/tags/v* ]]; then
+            backend_tags+=(
+              "${dockerhub_backend_base}:${GITHUB_REF_NAME}"
+              "${nudev_backend_base}:${GITHUB_REF_NAME}"
+            )
+            web_tags+=(
+              "${dockerhub_web_base}:${GITHUB_REF_NAME}"
+              "${nudev_web_base}:${GITHUB_REF_NAME}"
+            )
+
+            # Publish latest only for stable tags (e.g. v1.2.3, not v1.2.3-rc1).
+            if [[ "${GITHUB_REF_NAME}" != *-* ]]; then
+              backend_tags+=(
+                "${dockerhub_backend_base}:latest"
+                "${nudev_backend_base}:latest"
+              )
+              web_tags+=(
+                "${dockerhub_web_base}:latest"
+                "${nudev_web_base}:latest"
+              )
+            fi
+          fi
+
+          {
+            echo "backend_tags<<EOF"
+            printf '%s\n' "${backend_tags[@]}"
+            echo "EOF"
+            echo "web_tags<<EOF"
+            printf '%s\n' "${web_tags[@]}"
+            echo "EOF"
+            echo "dockerhub_backend_ref=${dockerhub_backend_base}:sha-${short_sha}"
+            echo "dockerhub_web_ref=${dockerhub_web_base}:sha-${short_sha}"
+            echo "nudev_backend_ref=${nudev_backend_base}:sha-${short_sha}"
+            echo "nudev_web_ref=${nudev_web_base}:sha-${short_sha}"
+          } >> "$GITHUB_OUTPUT"
+
+      - name: Build and push backend
+        uses: docker/build-push-action@v6
+        with:
+          context: .
+          file: ./Dockerfile
+          push: true
+          tags: ${{ steps.refs.outputs.backend_tags }}
+          build-args: |
+            VERSION=${{ github.ref_name }}
+            COMMIT=${{ github.sha }}
+
+      - name: Build and push web
+        uses: docker/build-push-action@v6
+        with:
+          context: .
+          file: ./Dockerfile.web
+          push: true
+          tags: ${{ steps.refs.outputs.web_tags }}
+          build-args: |
+            REMOTE_API_URL=http://backend:8080
+            NEXT_PUBLIC_KEYCLOAK_ISSUER_URL=${{ vars.NEXT_PUBLIC_KEYCLOAK_ISSUER_URL }}
+            NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=${{ vars.NEXT_PUBLIC_KEYCLOAK_CLIENT_ID }}
+            NEXT_PUBLIC_KEYCLOAK_AUTH_URL=${{ vars.NEXT_PUBLIC_KEYCLOAK_AUTH_URL }}
+            NEXT_PUBLIC_WS_URL=${{ vars.NEXT_PUBLIC_WS_URL }}
+
+  smoke:
+    runs-on: ubuntu-latest
+    needs: build-and-push
+    steps:
+      - name: Login to Docker Hub
+        uses: docker/login-action@v3
+        with:
+          username: ${{ secrets.DOCKERHUB_USERNAME }}
+          password: ${{ secrets.DOCKERHUB_TOKEN }}
+
+      - name: Login to NuDev registry
+        uses: docker/login-action@v3
+        with:
+          registry: ${{ secrets.REGISTRY_URL }}
+          username: ${{ secrets.REGISTRY_USERNAME }}
+          password: ${{ secrets.REGISTRY_PASSWORD }}
+
+      - name: Pull published images
+        run: |
+          set -euo pipefail
+          docker pull "${{ needs.build-and-push.outputs.dockerhub_backend_ref }}"
+          docker pull "${{ needs.build-and-push.outputs.dockerhub_web_ref }}"
+          docker pull "${{ needs.build-and-push.outputs.nudev_backend_ref }}"
+          docker pull "${{ needs.build-and-push.outputs.nudev_web_ref }}"
+
+      - name: Backend health smoke
+        run: |
+          set -euo pipefail
+          docker network create multica-smoke
+          docker run -d --name smoke-postgres --network multica-smoke \
+            -e POSTGRES_DB=multica \
+            -e POSTGRES_USER=multica \
+            -e POSTGRES_PASSWORD=multica \
+            pgvector/pgvector:pg17
+
+          docker run -d --name smoke-backend --network multica-smoke -p 18080:8080 \
+            -e DATABASE_URL=postgres://multica:multica@smoke-postgres:5432/multica?sslmode=disable \
+            -e JWT_SECRET=smoke-secret \
+            -e FRONTEND_ORIGIN=http://localhost:13000 \
+            "${{ needs.build-and-push.outputs.dockerhub_backend_ref }}"
+
+          for _ in {1..40}; do
+            if curl -fsS http://localhost:18080/health >/dev/null; then
+              exit 0
+            fi
+            sleep 2
+          done
+
+          echo "backend /health check failed" >&2
+          docker logs smoke-backend || true
+          exit 1
+
+      - name: Web startup smoke
+        run: |
+          set -euo pipefail
+          docker run -d --name smoke-web -p 13000:3000 "${{ needs.build-and-push.outputs.dockerhub_web_ref }}"
+          for _ in {1..30}; do
+            if curl -fsS http://localhost:13000 >/dev/null; then
+              exit 0
+            fi
+            sleep 2
+          done
+
+          echo "web startup check failed" >&2
+          docker logs smoke-web || true
+          exit 1
+
+      - name: Cleanup
+        if: always()
+        run: |
+          docker rm -f smoke-web smoke-backend smoke-postgres >/dev/null 2>&1 || true
+          docker network rm multica-smoke >/dev/null 2>&1 || true
