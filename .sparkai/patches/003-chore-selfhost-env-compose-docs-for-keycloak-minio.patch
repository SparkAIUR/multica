+        NEXT_PUBLIC_KEYCLOAK_AUTH_URL: ${NEXT_PUBLIC_KEYCLOAK_AUTH_URL:-}
         NEXT_PUBLIC_WS_URL: ${NEXT_PUBLIC_WS_URL:-}
     depends_on:
       - backend
